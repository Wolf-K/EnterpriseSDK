{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [ "bin/*.dll" ],
          "exclude": [ "**/obj/**" ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false
    }
  ],
  "build": {
        "content": [
      { "files": [ "api/**.yml" ] },
      { "files": [ "api/**.md" ] }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "EnterpriseSDK",
      "_appTitle": "EnterpriseSDK",
      "_enableSearch": true,
      "pdf": false
    }
  }
}